APP_ENV=production
APP_DEBUG=false
APP_URL=http://161.248.4.210
APP_KEY=base64:replace_with_32_random_bytes_base64
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mailpanel
DB_USERNAME=mailpanel
DB_PASSWORD=change_me
GENERATED_ROOT=/var/lib/mailpanel/generated
VMAIL_ROOT=/var/vmail
VMAIL_UID=2000
VMAIL_GID=2000
AGENT_BINARY=/usr/local/bin/mailpanel-agent
WEB_AGENT_BINARY=/usr/local/bin/mailpanel-web-agent
SUDO_BINARY=sudo
AGENT_TIMEOUT_SECONDS=60
NGINX_ROOT=/opt/mailpanel/public
NGINX_SERVER_NAME=mail.example.com
NGINX_TLS_CERTIFICATE=/etc/ssl/certs/ssl-cert-snakeoil.pem
NGINX_TLS_PRIVATEKEY=/etc/ssl/private/ssl-cert-snakeoil.key
NGINX_PHP_FPM_SOCKET=/run/php/php8.3-fpm.sock
EXIM_TLS_CERTIFICATE=/etc/exim4/ssl/mailpanel.pem
EXIM_TLS_PRIVATEKEY=/etc/exim4/ssl/mailpanel.key
EXIM_SUBMISSION_PORTS=25 : 465 : 587
EXIM_AUTH_PORTS=465 : 587
EXIM_TLS_ON_CONNECT_PORTS=465
WEBMAIL_PATH=/webmail
ACME_EMAIL=admin@example.com
ACME_WEBROOT=/var/www/acme
ACME_AUTO_ISSUE_ON_DOMAIN_CREATE=true
ACME_DEFAULT_PROFILE=mail_only
TLS_SNI_ROOT=/etc/mailpanel/tls/sni
TENANT_EXPIRY_WARNING_DAYS=14
TENANT_DEFAULT_GRACE_DAYS=7
TENANT_EXPIRED_INBOUND_MODE=accept
SUPER_ADMIN_IP_ALLOWLIST_ENABLED=false
SUPER_ADMIN_IP_ALLOWLIST=0.0.0.0/0
TOTP_ENCRYPTION_KEY=
RATE_LIMIT_API_MAX_ATTEMPTS=120
RATE_LIMIT_API_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_ADMIN_LOGIN_WINDOW_SECONDS=900
RATE_LIMIT_MAILBOX_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_MAILBOX_LOGIN_WINDOW_SECONDS=900
RATE_LIMIT_MAILBOX_PASSWORD_CHANGE_MAX_ATTEMPTS=5
RATE_LIMIT_MAILBOX_PASSWORD_CHANGE_WINDOW_SECONDS=900
PASSWORD_RESET_TTL_SECONDS=3600
PASSWORD_RESET_FROM_EMAIL=no-reply@example.com
PASSWORD_RESET_FROM_NAME=MailPanel
PASSWORD_RESET_SUBJECT=Đặt lại mật khẩu MailPanel
PASSWORD_RESET_MAIL_TRANSPORT=mail
PASSWORD_RESET_SMTP_HOST=
PASSWORD_RESET_SMTP_PORT=587
PASSWORD_RESET_SMTP_ENCRYPTION=starttls
PASSWORD_RESET_SMTP_USERNAME=
PASSWORD_RESET_SMTP_TIMEOUT_SECONDS=15
RATE_LIMIT_PASSWORD_RESET_MAX_ATTEMPTS=5
RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS=900
RATE_LIMIT_PASSWORD_RESET_COMPLETE_MAX_ATTEMPTS=8
RATE_LIMIT_PASSWORD_RESET_COMPLETE_WINDOW_SECONDS=900
ADMIN_TOTP_GRACE_LOGINS=5
